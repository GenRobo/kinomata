{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build: debug",
            "type": "shell",
            "command": "./build.sh",
            "args": [
                "--config=debug"
            ],
            "windows": {
                "command": "${workspaceFolder}\\build.bat",
                "args": [
                    "--config=debug"
                ]
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "build: release",
            "type": "shell",
            "command": "./build.sh",
            "args": [
                "--config=release"
            ],
            "windows": {
                "command": "${workspaceFolder}\\build.bat",
                "args": [
                    "--config=release"
                ]
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "build: relwithdebinfo",
            "type": "shell",
            "command": "./build.sh",
            "args": [
                "--config=relwithdebinfo"
            ],
            "windows": {
                "command": "${workspaceFolder}\\build.bat",
                "args": [
                    "--config=relwithdebinfo"
                ]
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "rebuild",
            "type": "shell",
            "command": "./build.sh",
            "args": [
                "--clean",
                "--config=${input:buildConfig}"
            ],
            "windows": {
                "command": "${workspaceFolder}\\build.bat",
                "args": [
                    "--clean",
                    "--config=${input:buildConfig}"
                ]
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "run: debug",
            "type": "shell",
            "command": "./run.sh",
            "args": [],
            "windows": {
                "command": "${workspaceFolder}\\build\\win-x64\\src\\Debug\\kinomata.exe",
                "args": []
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": [
                "build: debug"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "run: release",
            "type": "shell",
            "command": "./run.sh",
            "args": [
                "--release"
            ],
            "windows": {
                "command": "${workspaceFolder}\\build\\win-x64\\src\\Release\\kinomata.exe",
                "args": []
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": [
                "build: release"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "run: relwithdebinfo",
            "type": "shell",
            "command": "./run.sh",
            "args": [
                "--relwithdebinfo"
            ],
            "windows": {
                "command": "${workspaceFolder}\\build\\win-x64\\src\\RelWithDebInfo\\kinomata.exe",
                "args": []
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": [
                "build: relwithdebinfo"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "buildConfig",
            "type": "pickString",
            "description": "Select the build configuration for the rebuild task",
            "options": [
                "debug",
                "release",
                "relwithdebinfo"
            ],
            "default": "debug"
        }
    ]
}
